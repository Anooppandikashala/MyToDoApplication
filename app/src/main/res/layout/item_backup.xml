<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:descendantFocusability="blocksDescendants">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        app:cardBackgroundColor="@color/colorSurface"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp"
        app:strokeColor="@color/colorOutlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <!-- Database file icon -->
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/circle_avatar_bg">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="Backup"
                    android:src="@drawable/baseline_check_circle_24"
                    app:tint="@color/colorOnPrimaryContainer" />

            </FrameLayout>

            <TextView
                android:id="@+id/backupName"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:ellipsize="middle"
                android:maxLines="1"
                android:text="todo_backup_2026-01-01_12-00-00.db"
                android:textColor="@color/colorOnSurface"
                android:textSize="13sp" />

            <ImageButton
                android:id="@+id/deleteBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Delete"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:src="@drawable/ic_delete_forever_red_24dp"
                app:tint="@color/colorDeleteRed" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
